app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# -----------------------------------------------------------------------
# Generated / local artifacts — not source code
# -----------------------------------------------------------------------
.firebase/
*_repomix*.xml
vilas_magazine_*.xml

# -----------------------------------------------------------------------
# Credentials — NEVER commit any of these
# -----------------------------------------------------------------------
*serviceAccountKey*.json
*service-account*.json
.env
.env.*
functions/.env
*.p8
*.p12
*.pem
*.key

# -----------------------------------------------------------------------
# Firebase config files — intentionally tracked in this project
# These contain non-secret client-side identifiers required at runtime.
# -----------------------------------------------------------------------
!lib/firebase_options.dart
!ios/Runner/GoogleService-Info.plist
!android/app/google-services.json
